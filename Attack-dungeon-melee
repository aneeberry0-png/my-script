local RunService = game:GetService("RunService")
local Players = game:GetService("Players")
local player = Players.LocalPlayer

-- ===== CONFIG GỘP LẠI NÈ ANN OII (ﾉ◕ヮ◕)ﾉ*:･ﾟ✧ =====
local ENEMY_FOLDER_NAME = "Enemies" 
local MAX_DISTANCE = 1000 
local IGNORED_ENEMY = "Blank Buddy" 
local TP_DELAY = 0.2 
local GATHER_RADIUS = 35 
local LUNGE_SPEED = 400
local PLAYER_CHECK_RADIUS = 35 
-- ==================================================

local movementToken = 0

local function getHRP()
    local char = player.Character or player.CharacterAdded:Wait()
    return char:WaitForChild("HumanoidRootPart")
end

-- Hàm check xem ann có đang ở phòng Boss hông mò (=^･ω･^=)
local function isBossRoom()
    local map = workspace:FindFirstChild("Map")
    local dungeon = map and map:FindFirstChild("Dungeon")
    if dungeon then
        local maxRoomNum = 0
        -- Tìm cái phòng có số lớn nhất trước nè oii (っ˘ω˘ς)
        for _, room in ipairs(dungeon:GetChildren()) do
            local roomNum = tonumber(room.Name)
            if roomNum and roomNum > maxRoomNum then
                maxRoomNum = roomNum
            end
        end
        
        -- Xong rùi mới đem chia 5 check boss nhó (≧◡≦)
        if maxRoomNum > 0 then
            return (maxRoomNum % 5 == 0), maxRoomNum 
        end
    end
    return false, 0
end

-- ==========================================
-- CÁC HÀM PHỤ CỦA SCRIPT NORMAL (っ˘ω˘ς)
-- ==========================================
local function findNearestExitRoot()
    local map = workspace:FindFirstChild("Map")
    local dungeon = map and map:FindFirstChild("Dungeon")
    
    if not dungeon then 
        warn("Hông tìm thấy Dungeon oii! (๑•́ ₃ •̀๑)")
        return nil 
    end

    local hrp = getHRP()
    local nearestRoot = nil
    local minDistance = math.huge

    for _, room in ipairs(dungeon:GetChildren()) do
        local exitPortal = room:FindFirstChild("ExitTeleporter")
        if exitPortal then
            local root = exitPortal:FindFirstChild("Root")
            if root and root:IsA("BasePart") then
                local dist = (hrp.Position - root.Position).Magnitude
                if dist < minDistance then
                    minDistance = dist
                    nearestRoot = root
                end
            end
        end
    end

    return nearestRoot 
end

local function createPlatform(position)
    local platform = workspace:FindFirstChild("AnnSafePlatform")
    if not platform then
        platform = Instance.new("Part")
        platform.Name = "AnnSafePlatform"
        platform.Size = Vector3.new(20, 1, 20) 
        platform.Position = position
        platform.Anchored = true
        platform.CanCollide = true
        platform.Transparency = 0.5 
        platform.Color = Color3.fromRGB(138, 43, 226) 
        platform.Parent = workspace
    else
        platform.Position = position
    end
    return platform
end

-- ==========================================
-- CÁC HÀM PHỤ CỦA SCRIPT BOSS ( =ω= )
-- ==========================================
local function isOtherPlayerNear(monsterHRP)
    for _, otherPlayer in pairs(Players:GetPlayers()) do
        if otherPlayer ~= player and otherPlayer.Character and otherPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local distToMonster = (monsterHRP.Position - otherPlayer.Character.HumanoidRootPart.Position).Magnitude
            if distToMonster <= PLAYER_CHECK_RADIUS then
                return true -- Có ngừi rùi, meyy~ bảo ann nhường họ nhó (๑•́ ₃ •̀๑)
            end
        end
    end
    return false -- Trống trải waa~, dứt nó ik ann oii!
end

local function stopMovement()
    movementToken += 1
end

local function lungeTo(targetPos)
    local hrp = getHRP()
    local myToken = movementToken
    local startPos = hrp.Position
    local delta = targetPos - startPos
    local dist = delta.Magnitude
    if dist < 0.5 then return end

    local dir = delta.Unit
    local duration = dist / LUNGE_SPEED
    local elapsed = 0

    local conn
    conn = RunService.Heartbeat:Connect(function(dt)
        if myToken ~= movementToken then
            conn:Disconnect()
            return
        end
        elapsed += dt
        local alpha = math.clamp(elapsed / duration, 0, 1)
        hrp.CFrame = CFrame.new(startPos + dir * (dist * alpha))
        if alpha >= 1 then
            conn:Disconnect()
        end
    end)
    
    repeat task.wait() until elapsed >= duration or myToken ~= movementToken
end

