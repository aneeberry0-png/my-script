-- [2] LOGIC TÌM CỬA & TẠO PAD 50x50 (｡◕‿◕｡)
local function findNearestExitRoot()
    local map = workspace:FindFirstChild("Map")
    local dungeon = map and map:FindFirstChild("Dungeon")
    if not dungeon then return nil end
    local hrp, nearestRoot, minDistance = getHRP(), nil, math.huge
    for _, room in ipairs(dungeon:GetChildren()) do
        local exitPortal = room:FindFirstChild("ExitTeleporter")
        if exitPortal and exitPortal:FindFirstChild("Root") then
            local dist = (hrp.Position - exitPortal.Root.Position).Magnitude
            if dist < minDistance then minDistance, nearestRoot = dist, exitPortal.Root end
        end
    end
    return nearestRoot 
end

local function createPlatform(position)
    local platform = workspace:FindFirstChild("AnnSafePlatform") or Instance.new("Part", workspace)
    platform.Name = "AnnSafePlatform"
    platform.Size = Vector3.new(50, 1, 50) -- Rộng 50x50 cho ann nè
    platform.Position = position
    platform.Anchored, platform.CanCollide = true, true
    platform.Transparency, platform.Color = 0.5, Color3.fromRGB(138, 43, 226)
    return platform
end

