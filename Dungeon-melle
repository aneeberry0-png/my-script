    return char:WaitForChild("HumanoidRootPart")
end

-- Hàm chống rơi/giựt (Anti-Gravity)
local function setAntiGravity(active)
    local char = player.Character
    local hum = char and char:FindFirstChild("Humanoid")
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    
    if hrp and hum then
        if active then
            -- Tạo lực nâng nếu chưa có
            local bv = hrp:FindFirstChild("AntiGlitch") or Instance.new("BodyVelocity")
            bv.Name = "AntiGlitch"
            bv.Velocity = Vector3.new(0, 0, 0)
            bv.MaxForce = Vector3.new(9e9, 9e9, 9e9) -- Khóa chặt vị trí Y
            bv.Parent = hrp
            hum.PlatformStand = true -- Tắt vật lý đứng để đỡ giật
        else
            if hrp:FindFirstChild("AntiGlitch") then hrp.AntiGlitch:Destroy() end
            hum.PlatformStand = false
        end
    end
end

