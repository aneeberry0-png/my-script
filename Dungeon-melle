-- Hàm để chọn Fruit (Ô số 2)
function equipFruitSlot()
    local character = localPlayer.Character
    local backpack = localPlayer.Backpack
    
    if character then
        -- Kiểm tra xem trên tay đã cầm Tool nào chưa
        local currentlyEquipped = character:FindFirstChildOfClass("Tool")
        
        -- Nếu chưa cầm hoặc cái đang cầm không phải Fruit thì mới chọn
        -- Ở đây mình tìm item dựa trên ToolTip là "Blox Fruit" (chuẩn của game)
        for _, item in pairs(backpack:GetChildren()) do
            if item:IsA("Tool") and item.ToolTip == "Melee" then
                character.Humanoid:EquipTool(item)
                break
            end
        end
    end
end

