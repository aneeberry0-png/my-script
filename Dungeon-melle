-- 2. HÀM DI CHUYỂN TRÊN ĐẦU (ĐÃ FIX GIỰT)
local function hoverAboveTarget(targetEnemy)
    local hrp = getHRP()
    local targetHRP = targetEnemy:FindFirstChild("HumanoidRootPart")
    local targetHum = targetEnemy:FindFirstChild("Humanoid")
    local myToken = movementToken

    setAntiGravity(true) -- Bật chống giựt khi bắt đầu target

    while targetHum and targetHum.Health > 0 and myToken == movementToken do
        if not targetHRP or not targetHRP.Parent then break end
        
        local enemyPos = targetHRP.Position
        local targetPos = enemyPos + Vector3.new(0, HEIGHT_ABOVE, 0)
        local currentPos = hrp.Position
        local dist = (targetPos - currentPos).Magnitude

        if dist > 0.1 then
            local dir = (targetPos - currentPos).Unit
            hrp.CFrame = (hrp.CFrame - hrp.Position) + (currentPos + dir * math.min(dist, MOVE_SPEED * task.wait()))
        else
            -- Đứng yên trên đầu quái nhưng cập nhật theo quái di chuyển
            hrp.CFrame = (hrp.CFrame - hrp.Position) + targetPos
            task.wait()
        end
        if not targetEnemy.Parent then break end
    end
    
    setAntiGravity(false) -- Tắt khi xong việc
end

-- 3. VÒNG LẶP QUÉT QUÁI
task.spawn(function()
    while true do
        local folder = workspace:FindFirstChild(ENEMY_FOLDER_NAME)
        local myHRP = getHRP()

        if folder and myHRP then
            for _, enemy in pairs(folder:GetChildren()) do
                if enemy.Name == IGNORED_ENEMY then continue end
                local eHRP = enemy:FindFirstChild("HumanoidRootPart")
                local eHum = enemy:FindFirstChild("Humanoid")
                
                if eHRP and eHum and eHum.Health > 0 then
                    if (eHRP.Position - myHRP.Position).Magnitude <= MAX_DISTANCE then
                        movementToken += 1
                        hoverAboveTarget(enemy)
                    end
                end
            end
        end
        task.wait(0.1) 
    end
end)
