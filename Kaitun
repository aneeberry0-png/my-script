local function GetRole()
    local myName = game:GetService("Players").LocalPlayer.Name:lower()
    for _, n in pairs(getgenv().Configs["Account Join Raid"]) do
        if n:lower() == myName then return "Account Join Raid" end
    end
    for _, n in pairs(getgenv().Configs["Account Join"]) do
        if n:lower() == myName then return "Account Join" end
    end
    return nil
end

