local function tp(cframe)
    if plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
        plr.Character.HumanoidRootPart.CFrame = cframe
    end
end

local function getPlayersInDungeon(center)
    local count = 0
    for _, player in pairs(ply:GetPlayers()) do
        if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            if (player.Character.HumanoidRootPart.Position - center).Magnitude <= DungeonRadius then
                count = count + 1
            end
        end
    end
    return count
end

-- Logic Acc Chủ
local function JoinDungeonTeleport()
    while task.wait(0.5) do
        if _G.AccjoinRaid then
            for _, dungeon in pairs(Dungeons) do
                if getPlayersInDungeon(dungeon.center) == 0 then
                    StatusFarmLabel.Text = "Status Farm: Entering " .. dungeon.name
                    _G.FoundDungeon = dungeon.name
                    tp(CFrame.new(dungeon.center + Vector3.new(0, 3, 0)))
                    
                    task.wait(4)
                    _G.StartDuggeon = true
                    _G.AccjoinRaid = false
                    break
                end
            end
        end
    end
end

-- Logic Acc Phụ (Follow)
local function Accountteleaccjoin()
    local leaderName = CFG["Account Join Raid"][1]:lower()
    
    while task.wait(0.5) do
        if _G.AccountJoin then
            local leader = nil
            for _, v in pairs(game.Players:GetPlayers()) do
                if v.Name:lower() == leaderName then
                    leader = v
                    break
                end
            end
            
            if leader and leader.Character and leader.Character:FindFirstChild("HumanoidRootPart") then
                local leaderPos = leader.Character.HumanoidRootPart.Position
                local isLeaderInPad = false
                
                for _, dungeon in pairs(Dungeons) do
                    local distance = (leaderPos - dungeon.center).Magnitude
                    if distance <= DungeonRadius then
                        isLeaderInPad = true
                        _G.FoundDungeon = dungeon.name
                        break
                    end
                end

                if isLeaderInPad then
                    tp(leader.Character.HumanoidRootPart.CFrame)
                    StatusFarmLabel.Text = "Status Farm: tp to pad"
                    
                    task.wait(2)
                    _G.StartDuggeon = true
                else
                    StatusFarmLabel.Text = "Status Farm: waiting leader"
                    _G.StartDuggeon = false
                end
            else
                StatusFarmLabel.Text = "Status Farm: searching for leader"
            end
        end
    end
end

-- Logic Start
local function StartDungeon()
    while task.wait(0.5) do
        if _G.StartDuggeon then
            local padName = nil
            
            if _G.FoundDungeon == "Dungeon 1" then 
                padName = "DUNGEON_TELEPORTER1"
            elseif _G.FoundDungeon == "Dungeon 2" then
                padName = "DUNGEON_TELEPORTER2"
            elseif _G.FoundDungeon == "Dungeon 3" then
                padName = "DUNGEON_TELEPORTER3"
            end

            if padName then
                pcall(function()
                    local event = workspace:WaitForChild("Map"):WaitForChild("Simulation Hub"):WaitForChild("Pads"):WaitForChild(padName):WaitForChild("DungeonSettingsChanged")
                    event:FireServer("Difficulty", CFG["Select Difficulty"])
                    task.wait(0.5)
                    event:FireServer("Start")
                end)
                _G.StartDuggeon = false
            end
        end
    end
end

