        if Workspace.Map:FindFirstChild("Dungeon") then
            -- Nếu đang trong Dungeon thì tự động cầm vũ khí nhó (っ˘ω˘ς)
            equipToolByRole()
            task.wait(0.5) -- Check nhanh một xíu khi đang đi Raid
        else
            -- Nếu hông có Dungeon (ở map thường) thì nghỉ ngơi xíu nhó
            task.wait(2) 
        end
    end
end)
