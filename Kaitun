local DungeonRadius = 10
local Dungeons = {
    {name = "Dungeon 1", center = Vector3.new(-487.545013, 232.758224, -433.559204)},
    {name = "Dungeon 2", center = Vector3.new(-360.278137, 232.758224, -447.755859)},
    {name = "Dungeon 3", center = Vector3.new(-231.965485, 232.758224, -433.251038)},
}

local function tp(cframe)
    local character = plr.Character
    if not character then return end
    local root = character:FindFirstChild("HumanoidRootPart")
    if root then
        root.CFrame = cframe
    end
end

local function getPlayersInDungeon(center)
    local playersInside = {}
    for _, player in pairs(game.Players:GetPlayers()) do
        local char = player.Character
        if char then
            local root = char:FindFirstChild("HumanoidRootPart")
            if root then
                local dist = (root.Position - center).Magnitude
                if dist <= DungeonRadius then
                    table.insert(playersInside, player.Name)
                end
            end
        end
    end
    return playersInside
end


_G.FoundDungeon = nil  -- Chỉ lưu tên dungeon

local function JoinDungeonTeleport()
    while task.wait(0.5) do
        if _G.AccjoinRaid then
            local joined = false

            for _, dungeon in pairs(Dungeons) do
                local players = getPlayersInDungeon(dungeon.center)

                if #players == 0 then
                    print("✅ " .. dungeon.name .. " đang trống → Teleport vào!")
                    StatusFarmLabel.Text = "Status Farm: wait" .. dungeon.name
                    
                    -- ✅ TẮT FLAG NGAY LẬP TỨC
                    _G.AccjoinRaid = false
                    _G.FoundDungeon = dungeon.name
                    
                    tp(CFrame.new(dungeon.center + Vector3.new(0, 3, 0)))
                    
                    -- ✅ ĐỢI 2 GIÂY ĐỂ CHẮC CHẮN ĐÃ VÀO
                    task.wait(2)
                    
                    _G.StartDuggeon = true
                    joined = true
                    StatusFarmLabel.Text = " done join " .. dungeon.name
                    break -- Break khỏi vòng for

                else
                    print("❌ " .. dungeon.name .. " đã có " .. #players .. " người")
                end
            end

            if not joined then
                print("⏳ Tất cả Dungeon đều có người, thử lại...")
                StatusFarmLabel.Text = "Status Farm: wait dungeon no player..."
            end
            
            -- ✅ QUAN TRỌNG: BREAK KHỎI VÒNG WHILE NẾU ĐÃ JOIN THÀNH CÔNG
            if joined then
                
                break -- Thoát khỏi vòng while hoàn toàn

            end
        end
    end
end
