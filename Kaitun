
local Workspace = game:GetService("Workspace")
local plr = game:GetService("Players").LocalPlayer

if Workspace.Map:FindFirstChild("Dungeon") then
    loadstring(game:HttpGet("https://raw.githubusercontent.com/aneeberry0-png/my-script/refs/heads/main/main-dungeon"))()
else
    loadstring(game:HttpGet("https://raw.githubusercontent.com/aneeberry0-png/my-script/refs/heads/main/pad"))()
end

local function getCurrentToolTip()
    if not getgenv().Configs then return nil end
    local myName = string.lower(plr.Name)
    local myDisplayName = string.lower(plr.DisplayName)
    
    for _, data in pairs(getgenv().Configs) do
        if type(data) == "table" and data.Users then
            for _, user in pairs(data.Users) do
                local configUser = string.lower(tostring(user))
                if configUser == myName or configUser == myDisplayName then 
                    return data.ToolTip 
                end
            end
        end
    end
    return nil
end

local function equipToolByRole()
    local myToolTip = getCurrentToolTip()
    if not myToolTip then return end
    
    local character = plr.Character
    local backpack = plr:FindFirstChild("Backpack")
    
    if character and backpack then
        local hum = character:FindFirstChild("Humanoid")
        local currentlyEquipped = character:FindFirstChildOfClass("Tool")
        
        -- Nếu đang cầm đúng cái tool có ToolTip đó rồi thì thôi nhó (๑˃ᴗ˂)ﻭ
        if currentlyEquipped and currentlyEquipped.ToolTip == myToolTip then return end
        
        for _, item in pairs(backpack:GetChildren()) do
            if item:IsA("Tool") and item.ToolTip == myToolTip then
                if hum then
                    hum:EquipTool(item)
                end
                break
            end
        end
    end
end

task.spawn(function()
    while true do
        if Workspace.Map:FindFirstChild("Dungeon") then
            equipToolByRole()
            task.wait(0.5)
        else
            task.wait(2) 
        end
    end
end)
