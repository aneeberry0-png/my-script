local function StartDungeon()
    while task.wait(0.5) do
        if _G.StartDuggeon then
            print("Starting dungeon...")
            StatusFarmLabel.Text = "Status Farm: Bắt đầu dungeon..."

            local dungeon_teleporter = nil
            if _G.FoundDungeon == "Dungeon 1" then 
                dungeon_teleporter = "DUNGEON_TELEPORTER1"
            elseif _G.FoundDungeon == "Dungeon 2" then
                dungeon_teleporter = "DUNGEON_TELEPORTER2"
            elseif _G.FoundDungeon == "Dungeon 3" then
                dungeon_teleporter = "DUNGEON_TELEPORTER3"
            end

            if dungeon_teleporter then
                
                workspace:WaitForChild("Map"):WaitForChild("Simulation Hub"):WaitForChild("Pads")
                    :WaitForChild(dungeon_teleporter):WaitForChild("DungeonSettingsChanged")
                    :FireServer("Difficulty", CFG["Select Difficulty"])
                
                task.wait(0.5)
                
               
                workspace:WaitForChild("Map"):WaitForChild("Simulation Hub"):WaitForChild("Pads")
                    :WaitForChild(dungeon_teleporter):WaitForChild("DungeonSettingsChanged")
                    :FireServer("Start")
                
                _G.StartDuggeon = false  
            else
                print("Lỗi: Không xác định được dungeon đã vào.")
            end
        end
    end
end

local function isInConfig(name, configTable)
    if type(configTable) == "table" then
        for _, v in pairs(configTable) do
            if v == name then return true end
        end
    elseif type(configTable) == "string" then
        return name == configTable
    end
    return false
end

local function joinDungeon()
    while task.wait(0.1) do
        local playername = plr.Name

        local AccJoinS = isInConfig(playername, CFG["Account Join Raid"])
        local AccJoin  = isInConfig(playername, CFG["Account Join"])

        if AccJoinS then
            print("Account Join Raid : " .. playername)
            StatusMobLabel.Text = "Your Account Status : Join Dungeon Teleport"
            _G.AccjoinRaid = true

        elseif AccJoin then
            print("Account Join : " .. playername)
            StatusMobLabel.Text = "Your Account Status : Join Account"
            _G.AccountJoin = true

        else
            print("Your account not have in config")
        end
    end
end


