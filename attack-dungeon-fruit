                local bAl=false
                for _,e in pairs(f:GetChildren())do 
                    if e.Name==IE then continue end;
                    local r=e:FindFirstChild("HumanoidRootPart")
                    local u=e:FindFirstChild("Humanoid")
                    if r and u and u.Health>0 then 
                        bAl=true
                        if (r.Position-h.Position).Magnitude<=MD then 
                            if _G.StatusMobLabel then _G.StatusMobLabel.Text="kill: "..e.Name.." (≧◡≦)" end
                            sM()lT(r.Position)
                        end 
                    end 
                end 
                
                if not bAl then
                    if _G.StatusFarmLabel then _G.StatusFarmLabel.Text="Next dungeon... (๑˃ᴗ˂)ﻭ" end
                    if _G.StatusMobLabel then _G.StatusMobLabel.Text="clear done! (≧ω≦)ﻭ" end
                end
            end;
