local FLY_SPEED = 350
local MAX_DISTANCE = 1000

local function gH()
    local c=p.Character or p.CharacterAdded:Wait()
    return c:WaitForChild("HumanoidRootPart")
end;

local function isAlive()
    local c = p.Character
    local u = c and c:FindFirstChild("Humanoid")
    return u and u.Health > 0
end;

local function iB()
    local m=workspace:FindFirstChild("Map")
    local d=m and m:FindFirstChild("Dungeon")
    if d then 
        local mR=0;
        for _,r in ipairs(d:GetChildren())do 
            local n=tonumber(r.Name)
            if n and n>mR then mR=n end 
        end;
        if mR>0 then return(mR%5==0),mR end 
    end;
    return false,0 
end;

local function fE()
    local m=workspace:FindFirstChild("Map")
    local d=m and m:FindFirstChild("Dungeon")
    if not d then return nil end;
    local h=gH()
    local n=nil;
    local mD=math.huge;
    for _,r in ipairs(d:GetChildren())do 
        local e=r:FindFirstChild("ExitTeleporter")
        if e then 
            local t=e:FindFirstChild("Root")
            if t and t:IsA("BasePart")then 
                local dist=(h.Position-t.Position).Magnitude;
                if dist<mD then mD=dist;n=t end 
            end 
        end 
    end;
    return n 
end;

local function cP(pos)
    local f=workspace:FindFirstChild("AnnSafePlatform")
    if not f then 
        f=Instance.new("Part")
        f.Name="AnnSafePlatform"
        f.Size=Vector3.new(100,1,100)
        f.Position=pos;
        f.Anchored=true;
        f.CanCollide=true;
        f.Transparency=0.5;
        f.Color=Color3.fromRGB(138,43,226)
        f.Parent=workspace 
    else 
        f.Position=pos 
    end;
    return f 
end;

local function sM()mT=mT+1 end;

local function lT(tP)
    local h=gH()
    local k=mT;
    local dist=(tP-h.Position).Magnitude;
    if dist<0.5 then return end;
    local dur=dist/LS;
    local ti=TweenInfo.new(dur,Enum.EasingStyle.Linear)
    local tw=TS:Create(h,ti,{CFrame=CFrame.new(tP)})
    tw:Play()
    repeat task.wait()until tw.PlaybackState==Enum.PlaybackState.Completed or k~=mT
    if k~=mT then tw:Cancel()end
end;

local function flyToNearestExit(targetPos)
    sM() 
    local myToken = mT
    local hrp = gH()
    local startPos = hrp.Position
    local delta = targetPos - startPos
    local distance = delta.Magnitude
    
    if distance < 3 then return end 

    local direction = delta.Unit
    local duration = distance / FLY_SPEED
    local elapsed = 0

    local connection
    connection = R.Heartbeat:Connect(function(dt)
        if myToken ~= mT then
            connection:Disconnect()
            return
        end

        elapsed += dt
        local alpha = math.clamp(elapsed / duration, 0, 1)
        hrp.CFrame = CFrame.new(startPos + direction * (distance * alpha))

        if alpha >= 1 then
            connection:Disconnect()
        end
    end)
    
    repeat task.wait() until elapsed >= duration or myToken ~= mT
end

local function executeFlyToNearestExit()
    local map = workspace:FindFirstChild("Map")
    local dungeon = map and map:FindFirstChild("Dungeon")
    if not dungeon then return end

    local hrp = gH()
    local nearestRoot = nil
    local minDistance = math.huge

    for _, room in ipairs(dungeon:GetChildren()) do
        local exitPortal = room:FindFirstChild("ExitTeleporter")
        if exitPortal then
            local root = exitPortal:FindFirstChild("Root")
            if root and root:IsA("BasePart") then
                local dist = (hrp.Position - root.Position).Magnitude
                if dist < minDistance then
                    minDistance = dist
                    nearestRoot = root
                end
            end
        end
    end

    if nearestRoot then
        flyToNearestExit(nearestRoot.Position + Vector3.new(0, 3, 0))
    end
end

local function getCurrentRoomNumber()
    local m=workspace:FindFirstChild("Map")
    local d=m and m:FindFirstChild("Dungeon")
    if not d then return 0 end
    local h=gH()
    if not h then return 0 end
    local cR=0
    local mD=math.huge
    for _,r in ipairs(d:GetChildren())do 
        local n=tonumber(r.Name)
        if n then
            local e=r:FindFirstChild("ExitTeleporter")
            local t=e and e:FindFirstChild("Root")
            if t then
                local dist=(h.Position-t.Position).Magnitude
                if dist<mD then mD=dist;cR=n end
            end
        end
    end
    return cR
end

