            local f=workspace:FindFirstChild(EF)
            local h=gH()
            if f and h then 
                local i={}
                for _,e in pairs(f:GetChildren())do 
                    if e.Name~=IE then 
                        local r=e:FindFirstChild("HumanoidRootPart")
                        local u=e:FindFirstChild("Humanoid")
                        if r and u and u.Health>0 and(r.Position-h.Position).Magnitude<=MD then 
                            table.insert(i,e)
                        end 
                    end 
                end;
                
                if #i>0 then 
                    for _,e in ipairs(i)do 
                        local r=e:FindFirstChild("HumanoidRootPart")
                        if r then h.CFrame=r.CFrame;task.wait(TD)end 
                    end;
                    local x=fE()
                    if x then 
                        local pP=x.Position+Vector3.new(0,10,0)
                        local pad=cP(pP)
                        local sC=CFrame.new(pP+Vector3.new(0,3,0))
                        h.CFrame=sC;task.wait(0.1)
                        
                        while true do 
                            local checkBoss, currentRoom = iB()
                            if checkBoss then break end;
                            local m={}
                            local lastEnemyName = ""
                            local enemiesAlive = 0
                            
                            for _,e in pairs(f:GetChildren())do 
                                if e.Name~=IE then 
                                    local r=e:FindFirstChild("HumanoidRootPart")
                                    local u=e:FindFirstChild("Humanoid")
                                    if r and u and u.Health>0 then
                                        enemiesAlive = enemiesAlive + 1
                                        lastEnemyName = e.Name
                                        if (r.Position-h.Position).Magnitude>GR then 
                                            table.insert(m,e)
                                        end 
                                    end 
                                end 
                            end;
                            
                            if enemiesAlive == 0 then
                                if _G.StatusFarmLabel then _G.StatusFarmLabel.Text="Next dungeon... (๑˃ᴗ˂)ﻭ" end
                                if _G.StatusMobLabel then _G.StatusMobLabel.Text="clear done!  ｡ﾟ( ﾟ^∀^ﾟ)ﾟ｡" end
                                break
                            else
                                if _G.StatusMobLabel then _G.StatusMobLabel.Text="kill: "..lastEnemyName.." (〃￣ω￣〃)ゞ" end
                            end

                            if #m==0 then break end;
                            for _,e in ipairs(m)do 
                                local r=e:FindFirstChild("HumanoidRootPart")
                                if r then h.CFrame=r.CFrame;task.wait(TD)end 
                            end;
                            h.CFrame=sC;task.wait(TD)task.wait(0.1)
                        end 
                    end 
                else
                    if _G.StatusFarmLabel then _G.StatusFarmLabel.Text="Next dungeon... (๑•́ ₃ •̀๑)" end
                    if _G.StatusMobLabel then _G.StatusMobLabel.Text="clear done...(๑•́ ₃ •̀๑)" end
                end
            end;
            task.wait(1)
        end 
    end 
end)
