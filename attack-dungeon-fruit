-- ================= SETTINGS CỦA ANN =================
local FLY_SPEED = 350
local MAX_DISTANCE = 1000
-- ====================================================

local function gH()
    local c=p.Character or p.CharacterAdded:Wait()
    return c:WaitForChild("HumanoidRootPart")
end;

local function isAlive()
    local c = p.Character
    local u = c and c:FindFirstChild("Humanoid")
    return u and u.Health > 0
end;

local function iB()
    local m=workspace:FindFirstChild("Map")
    local d=m and m:FindFirstChild("Dungeon")
    if d then 
        local mR=0;
        for _,r in ipairs(d:GetChildren())do 
            local n=tonumber(r.Name)
            if n and n>mR then mR=n end 
        end;
        if mR>0 then return(mR%5==0),mR end 
    end;
    return false,0 
end;

local function fE()
    local m=workspace:FindFirstChild("Map")
    local d=m and m:FindFirstChild("Dungeon")
    if not d then return nil end;
    local h=gH()
    local n=nil;
    local mD=math.huge;
    for _,r in ipairs(d:GetChildren())do 
        local e=r:FindFirstChild("ExitTeleporter")
        if e then 
            local t=e:FindFirstChild("Root")
            if t and t:IsA("BasePart")then 
                local dist=(h.Position-t.Position).Magnitude;
                if dist<mD then mD=dist;n=t end 
            end 
        end 
    end;
    return n 
end;

local function cP(pos)
    local f=workspace:FindFirstChild("AnnSafePlatform")
    if not f then 
        f=Instance.new("Part")
        f.Name="AnnSafePlatform"
        f.Size=Vector3.new(100,1,100)
        f.Position=pos;
        f.Anchored=true;
        f.CanCollide=true;
        f.Transparency=0.5;
        f.Color=Color3.fromRGB(138,43,226)
        f.Parent=workspace 
    else 
        f.Position=pos 
    end;
    return f 
end;

local function sM()mT=mT+1 end;

local function lT(tP)
    local h=gH()
    local k=mT;
    local dist=(tP-h.Position).Magnitude;
    if dist<0.5 then return end;
    local dur=dist/LS;
    local ti=TweenInfo.new(dur,Enum.EasingStyle.Linear)
    local tw=TS:Create(h,ti,{CFrame=CFrame.new(tP)})
    tw:Play()
    repeat task.wait()until tw.PlaybackState==Enum.PlaybackState.Completed or k~=mT
    if k~=mT then tw:Cancel()end
end;

-- [[ BÍ KÍP CỦA MEYY~: TIỄN BOSS XUỐNG VỰC ]]
local function forceMonsterToVoid(enemy)
    if not enemy then return end
    local hum = enemy:FindFirstChildOfClass("Humanoid")
    local root = enemy:FindFirstChild("HumanoidRootPart")
    if hum and root then
        hum.PlatformStand = true 
        for _, part in ipairs(enemy:GetDescendants()) do
            if part:IsA("BasePart") then
                part.CanCollide = false 
            end
        end
        root.AssemblyLinearVelocity = Vector3.new(0, -100, 0) 
    end
end
