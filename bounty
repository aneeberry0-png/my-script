-- Anti-Stuck Timer
spawn(function()
    while task.wait(0.5) do
        if not running or not ScanCompleted or not currentTarget or not Whitelist[currentTarget.Name] then
            lastDamageTime = tick()
            continue
        end
        
        if currentTarget and currentTarget.Character then
            local hum = currentTarget.Character:FindFirstChild("Humanoid")
            if hum then
                if lastTargetHealth == 0 then
                    lastTargetHealth = hum.Health
                elseif hum.Health < lastTargetHealth then
                    lastDamageTime = tick()
                    lastTargetHealth = hum.Health
                elseif hum.Health > lastTargetHealth then
                    lastTargetHealth = hum.Health
                end
            end
        end
        
        if tick() - lastDamageTime >= 90 then
            notify("Anti-Stuck", "No damage for 90s, hopping server!", 5, "Warning")
            lastDamageTime = tick()
            hopServer()
        end
    end
end)

local function startRandom()
    stopAll()
    running = true

    local myHrp = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if myHrp and (myHrp.Position.Y < 1800 or myHrp.Position.Y > 2000) then
        myHrp.CFrame = CFrame.new(myHrp.Position.X, 1900, myHrp.Position.Z)
        task.wait(2)
    end

    followThread = task.spawn(function()
        if not ScanCompleted then RunFullScan() end
        if not running then return end
        pickNewTarget("start")

        while running do
            task.wait(math.max(CONFIG.FollowDelay, 0.05))
            if not running then break end
            
            if not checkCurrentTarget() then task.wait(1); continue end
            
            if Whitelist[currentTarget.Name] then
                for i = 1, 5 do
                    if not running or not checkCurrentTarget() then break end
                    teleportTo(currentTarget)
                    task.wait(CONFIG.SkimDelay)
                end
                pickNewTarget("skimming cycle")
            else
                teleportTo(currentTarget)
            end
            
            switchTimer = switchTimer + CONFIG.FollowDelay
            if switchTimer >= CONFIG.SwitchDelay then pickNewTarget("auto rotation") end
        end
    end)
end

