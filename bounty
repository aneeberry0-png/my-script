local function stopAll()
    running = false
    IsScanning = false
    followThread = nil 
    currentTarget = nil
    switchTimer   = 0
end

local function hopServer()
    if isHopping then return end
    isHopping = true
    
    task.spawn(function()
        stopAll()
        pcall(function()
            local TeleportService = game:GetService("TeleportService")
            local HttpService     = game:GetService("HttpService")
            
            local url = "https://games.roblox.com/v1/games/"..game.PlaceId.."/servers/Public?sortOrder=Asc&limit=100"
            local response = game:HttpGetAsync(url)
            local data = HttpService:JSONDecode(response).data
            
            local possibleServers = {}
            for _, server in pairs(data) do
                if server.playing < 11 and server.id ~= game.JobId then
                    table.insert(possibleServers, server.id)
                end
            end
            
            if #possibleServers > 0 then
                local randomServerId = possibleServers[math.random(1, #possibleServers)]
                TeleportService:TeleportToPlaceInstance(game.PlaceId, randomServerId, LocalPlayer)
            else
                notify("Hop System", "No servers found, retrying...", 2, "Warning")
                task.wait(2)
                isHopping = false
                TeleportService:Teleport(game.PlaceId)
            end
        end)
    end)
end

