local DungeonRadius = 20 -- Tăng bán kính để dễ nhận diện
local Dungeons = {
    {name = "Dungeon 1", center = Vector3.new(-487.545, 232.758, -433.559)},
    {name = "Dungeon 2", center = Vector3.new(-360.278, 232.758, -447.755)},
    {name = "Dungeon 3", center = Vector3.new(-231.965, 232.758, -433.251)},
}

local function tp(cframe)
    if plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
        plr.Character.HumanoidRootPart.CFrame = cframe
    end
end

local function getPlayersInDungeon(center)
    local count = 0
    for _, player in pairs(ply:GetPlayers()) do
        if player.Character and player.Character:FindFirstChild("HumanoidRootPart") then
            if (player.Character.HumanoidRootPart.Position - center).Magnitude <= DungeonRadius then
                count = count + 1
            end
        end
    end
    return count
end

-- Logic Acc Chủ (ann_2k11x)
local function JoinDungeonTeleport()
    while task.wait(0.5) do
        if _G.AccjoinRaid then
            for _, dungeon in pairs(Dungeons) do
                if getPlayersInDungeon(dungeon.center) == 0 then
                    StatusFarmLabel.Text = "Status Farm: Entering " .. dungeon.name
                    _G.FoundDungeon = dungeon.name
                    tp(CFrame.new(dungeon.center + Vector3.new(0, 3, 0)))
                    
                    task.wait(4) -- Đợi các acc phụ bay vào
                    _G.StartDuggeon = true
                    _G.AccjoinRaid = false -- Dừng vòng lặp sau khi đã vào thành công
                    break
                end
            end
        end
    end
end

-- Logic Acc Phụ (Follow)
local function Accountteleaccjoin()
    local leaderName = CFG["Account Join Raid"][1]:lower() -- Chuyển về chữ thường để so sánh nè
    while task.wait(0.5) do
        if _G.AccountJoin then
            local leader = nil
            -- Tìm leader trong danh sách player mà hông sợ viết hoa/thường nhó
            for _, v in pairs(ply:GetPlayers()) do
                if v.Name:lower() == leaderName then
                    leader = v
                    break
                end
            end

            if leader and leader.Character and leader.Character:FindFirstChild("HumanoidRootPart") then
                local leaderPos = leader.Character.HumanoidRootPart.CFrame
                if leaderPos.Position.Y > 200 then
                    tp(leaderPos)
                    StatusFarmLabel.Text = "Status Farm: Following " .. leader.Name
                else
                    StatusFarmLabel.Text = "Status Farm: Waiting for Leader to move"
                end
            else
                StatusFarmLabel.Text = "Status Farm: Searching for Leader..."
            end
        end
    end
end

-- Logic Start
local function StartDungeon()
    while task.wait(0.5) do
        if _G.StartDuggeon then
            local padName = _G.FoundDungeon and _G.FoundDungeon:gsub("Dungeon ", "DUNGEON_TELEPORTER")
            if padName then
                local pad = workspace:WaitForChild("Map"):WaitForChild("Simulation Hub"):WaitForChild("Pads"):WaitForChild(padName)
                pad.DungeonSettingsChanged:FireServer("Difficulty", CFG["Select Difficulty"])
                task.wait(0.5)
                pad.DungeonSettingsChanged:FireServer("Start")
                _G.StartDuggeon = false
            end
        end
    end
end

-- PHÂN LOẠI VÀ KHỞI CHẠY (Fix lỗi so sánh tên)
local function Init()
    local name = plr.Name:lower()
    local isLeader = false
    local isMember = false

    for _, v in pairs(CFG["Account Join Raid"]) do if v:lower() == name then isLeader = true end end
    for _, v in pairs(CFG["Account Join"]) do if v:lower() == name then isMember = true end end

    if isLeader then
        StatusMobLabel.Text = "Your Account Status: Raid Leader"
        _G.AccjoinRaid = true
        task.spawn(JoinDungeonTeleport)
        task.spawn(StartDungeon)
    elseif isMember then
        StatusMobLabel.Text = "Your Account Status: Join Member"
        _G.AccountJoin = true
        task.spawn(Accountteleaccjoin)
    else
        StatusMobLabel.Text = "Your Account Status: Not in Config"
    end
end

