

local plr = game.Players.LocalPlayer

local function GetRole()
    local myName = plr.Name:lower()
    for _, n in pairs(getgenv().Configs["Account Join Raid"].Users) do
        if n:lower() == myName then return "Account Join Raid" end
    end
    for _, n in pairs(getgenv().Configs["Account Join"].Users) do
        if n:lower() == myName then return "Account Join" end
    end
    return nil
end

local myRole = GetRole()

if myRole == "Account Join Raid" then
    loadstring(game:HttpGet("https://raw.githubusercontent.com/aneeberry0-png/my-script/refs/heads/main/Dungeon-fruit"))()
elseif myRole == "Account Join" then
    loadstring(game:HttpGet("https://raw.githubusercontent.com/aneeberry0-png/my-script/refs/heads/main/Dungeon-melle"))()
else
    warn("Account not in Config. Script Stopped.")
end


