
local plr = game.Players.LocalPlayer

local function GetRole()
    local myName = plr.Name:lower()
    
    if getgenv().Configs and getgenv().Configs["Account Join Raid"] then
        for _, n in pairs(getgenv().Configs["Account Join Raid"].Users) do
            if n:lower() == myName then return "Account Join Raid" end
        end
    end
    
    if getgenv().Configs and getgenv().Configs["Account Join"] then
        for _, n in pairs(getgenv().Configs["Account Join"].Users) do
            if n:lower() == myName then return "Account Join" end
        end
    end
    
    return nil
end

local myRole = GetRole()

