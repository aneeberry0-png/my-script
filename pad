-- MEYY~ UI OPTIMIZER: Only update if text actually changes (｡◕‿◕｡)
local lastFarmText = ""
local lastMobText = ""

local function SetFarmStatus(text)
    if text ~= lastFarmText then
        lastFarmText = text
        _G.StatusFarmLabel.Text = text
    end
end

local function SetMobStatus(text)
    if text ~= lastMobText then
        lastMobText = text
        _G.StatusMobLabel.Text = text
    end
end

