local function CreateLabel(name, pos, text)
    local label = Instance.new("TextLabel")
    label.Name = name
    label.Parent = StatusMain
    label.AnchorPoint = Vector2.new(0.5, 0)
    label.BackgroundTransparency = 1
    label.Position = UDim2.new(0.5, 0, 0, pos)
    label.Size = UDim2.new(0, 300, 0, 18)
    label.Font = Enum.Font.GothamBold
    label.Text = text
    label.TextColor3 = Color3.fromRGB(0, 191, 255)
    label.TextSize = 16
    return label
end

